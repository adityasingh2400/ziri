APP_ENV=dev
APP_NAME=Ziri
ZIRI_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=*

AWS_REGION=us-east-1
AWS_ACCESS_KEY=<your_aws_access_key>
AWS_ACCESS_KEY_ID=<your_aws_access_key>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_key>
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
POLLY_VOICE_ID=Joanna
POLLY_ENGINE=neural
S3_TTS_BUCKET=
S3_TTS_PUBLIC_BASE_URL=

SUPABASE_URL=<your_supabase_url>
SUPABASE_SERVICE_ROLE_KEY=<your_supabase_service_role_key>

## Spotify — create an app at https://developer.spotify.com/dashboard
## Set redirect URI to http://localhost:8080/callback
## Then visit http://localhost:8000/spotify/auth to complete the OAuth flow
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/spotify/callback
SPOTIFY_USER_ACCESS_TOKEN=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_DEFAULT_DEVICE_ID=

GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_CALENDAR_ID=primary

DEVICE_MAP_PATH=app/config/device_map.yaml
SCENE_MAP_PATH=app/config/scenes.yaml
RETURN_AUDIO_URL=true
ENABLE_POLLY=false
MEMORY_WINDOW=8

## ElevenLabs TTS (primary voice engine)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=yj30vwTGJxSHezdAGsv9
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_192
ELEVENLABS_STREAMING_LATENCY=3
ELEVENLABS_STABILITY=0.55
ELEVENLABS_SIMILARITY_BOOST=0.85
ELEVENLABS_SPEED=1.2

## Location (for weather, sunrise/sunset)
USER_LATITUDE=40.7128
USER_LONGITUDE=-74.0060

## News (newsapi.org free tier)
NEWS_API_KEY=

## Langfuse observability (https://langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

## Semantic memory (pgvector)
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1:0
SEMANTIC_MEMORY_TOP_K=3
SEMANTIC_MEMORY_ENABLED=true

## Always-on listener (wake word + speaker filtering)
# Diarization via ElevenLabs Scribe: keep only the wake-word speaker’s words
SPEAKER_FILTER_ENABLED=true
SPEAKER_FILTER_PRE_WAKEWORD_SECS=1.5
